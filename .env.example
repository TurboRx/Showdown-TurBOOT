# ─── Pokémon Showdown Bot Configuration ──────────────────────────────────────

# WebSocket server URL (default: main PS server)
# PS_SERVER_URL=wss://sim3.psim.us/showdown/websocket

# Login API endpoint
# PS_LOGIN_URL=https://play.pokemonshowdown.com/api/login

# Bot credentials
PS_USERNAME=YourBotName
PS_PASSWORD=YourBotPassword

# Rooms to auto-join (comma-separated)
PS_ROOMS=lobby,help

# Avatar ID (optional)
# PS_AVATAR=169

# Reconnect delay in milliseconds (default: 10000 = 10 seconds)
# PS_RECONNECT_DELAY_MS=10000

# Command prefix character (default: .)
# PS_COMMAND_CHAR=.
